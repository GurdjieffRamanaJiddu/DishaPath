{
  "name": "edu-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "vitest run --config vitest.emulator.config.ts",
    "emulators": "bash scripts/emulators.sh",
    "seed": "node --env-file=.env.local scripts/seed.mjs",
    "seed:all": "node --env-file=.env.local scripts/seed-all.mjs",
    "seed:prod": "node --env-file=.env.prod scripts/seed-all.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
