# ---------------------------------------------------------------------------
# DishaPath production configuration (real Firebase project)
#
# Two places use these values:
#   1. Vercel  -> set them as Environment Variables in the Vercel dashboard.
#   2. Seeding -> copy this file to `.env.prod` (gitignored) and run
#                 `npm run seed:prod` once, to create the test parent + 16 students.
#
# Do NOT set NEXT_PUBLIC_FIREBASE_USE_EMULATOR or the *_EMULATOR_HOST vars in production.
# ---------------------------------------------------------------------------

# --- Web app config (Firebase console -> Project settings -> Your apps -> Web) ---
# These are public (they ship to the browser); that is expected and safe.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional:
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# --- Server-side Admin SDK credentials (SECRET, never commit) ---
# Firebase console -> Project settings -> Service accounts -> Generate new private key.
# Paste the whole JSON on ONE line.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id", ...}

# --- PIN hashing secret (SECRET) ---
# Use a long random string. It MUST be byte-for-byte identical in Vercel and in
# .env.prod, or student PIN login will fail (the stored hash will not match).
APP_SECRET=change-me-to-a-long-random-string
