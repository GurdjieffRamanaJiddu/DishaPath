# ---------------------------------------------------------------------------
# DishaPath environment configuration
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# --- LOCAL DEVELOPMENT WITH THE FIREBASE EMULATOR (no real project needed) ---
# Set this to "true" to make the browser SDK talk to the local emulators.
NEXT_PUBLIC_FIREBASE_USE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_PROJECT_ID=edu-app-demo

# These point the server-side Admin SDK at the emulators. Required when
# NEXT_PUBLIC_FIREBASE_USE_EMULATOR=true so /api routes use the emulator too.
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Secret used to hash child PINs. Use any random string for local dev.
APP_SECRET=local-dev-secret-change-me

# --- PRODUCTION (real Firebase project) ---
# Get these from Firebase console → Project settings → Your apps (Web app).
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
#
# Server-side Admin SDK credentials (a service-account JSON, single line):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", ...}
#
# In production, do NOT set NEXT_PUBLIC_FIREBASE_USE_EMULATOR or the *_EMULATOR_HOST vars.
